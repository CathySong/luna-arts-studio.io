# Contact form email service (Resend)
# Get your key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Studio email for receiving inquiries
STUDIO_EMAIL=hello@lunaartsstudio.com

# Future: Stripe for artwork purchases
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── Internal CRM (/admin) ───────────────────────────────────────────────────

ADMIN_PASSWORD=your-secure-password-here

# CRM storage: json = local data/crm/db.json | supabase = Supabase (production)
CRM_STORAGE=json

# ── Supabase (free tier) — see docs/supabase-setup.md ───────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Project Settings → API → service_role (secret)

# Production on Vercel:
# CRM_STORAGE=supabase

# Claude — personalized class reviews (Anthropic Messages API)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxx
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# 上课记录 AI 点评 — 默认读取 lib/crm/prompts/attendance-review.md
# ATTENDANCE_REVIEW_PROMPT_PATH=lib/crm/prompts/attendance-review.md
# ATTENDANCE_REVIEW_SYSTEM_PROMPT=   # 可选：单行 env 覆盖（不推荐，请改 .md）

# NotebookLM — optional student knowledge sync (pick ONE setup)

# Option A: Google NotebookLM Enterprise API
# Docs: https://cloud.google.com/gemini/enterprise/notebooklm-enterprise/docs/api-notebooks-sources
# NOTEBOOKLM_PROJECT_NUMBER=123456789
# NOTEBOOKLM_LOCATION=us
# NOTEBOOKLM_NOTEBOOK_ID=your-notebook-id
# NOTEBOOKLM_ACCESS_TOKEN=   # gcloud auth print-access-token

# Option B: Custom REST proxy (your org’s gateway)
# NOTEBOOKLM_BASE_URL=https://your-proxy.example.com/v1
# NOTEBOOKLM_CORPUS_ID=your-corpus-id
# NOTEBOOKLM_API_KEY=your-proxy-bearer-token
